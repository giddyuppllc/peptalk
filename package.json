{
  "name": "peptalk",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:calc": "tsx scripts/verify-calculator-math.ts",
    "verify:sanitize": "tsx scripts/verify-aimee-action-sanitize.ts",
    "verify:cycle": "tsx scripts/verify-cycle-predictor.ts",
    "verify:adherence": "tsx scripts/verify-dose-adherence.ts",
    "verify:labparsers": "tsx scripts/verify-lab-parsers.ts",
    "verify:mealmath": "tsx scripts/verify-meal-math.ts",
    "verify:dosecalc": "tsx scripts/verify-dose-calculator.ts",
    "verify:inbody": "tsx scripts/verify-inbody-parser.ts",
    "verify:stream-jwt": "tsx scripts/verify-stream-jwt.ts",
    "verify:all": "npm run verify:calc && npm run verify:sanitize && npm run verify:cycle && npm run verify:adherence && npm run verify:labparsers && npm run verify:mealmath && npm run verify:dosecalc && npm run verify:inbody && npm run verify:stream-jwt",
    "lint": "expo lint"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-iap",
          "react-native-health",
          "react-native-encrypted-storage"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "overrides": {
    "@expo/fingerprint": "0.15.4"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/ngrok": "~4.1.3",
    "@expo/vector-icons": "~15.0.3",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/themed": "^1.1.73",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@sentry/react-native": "~8.11.1",
    "@supabase/supabase-js": "~2.102.1",
    "expo": "~54.0.34",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "nativewind": "^4.2.3",
    "openai": "~6.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-encrypted-storage": "~4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health": "~1.19.0",
    "react-native-health-connect": "~3.5.0",
    "react-native-iap": "~15.2.0",
    "react-native-nitro-modules": "~0.35.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "3.4.17",
    "zustand": "~5.0.11"
